     def expand(self, s: str, l: int, r: int) -> str:
        # Expand outwards as long as it's a palindrome
        while l >= 0 and r < len(s) and s[l] == s[r]:
            l -= 1
            r += 1
        # Return the valid palindrome (slice is [l+1 : r])
        return s[l+1:r]
